@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find swift-atomics if needed
if(NOT TARGET Atomics)
    include(FetchContent)
    FetchContent_Declare(
        swift-atomics
        GIT_REPOSITORY https://github.com/apple/swift-atomics.git
        GIT_TAG        1.3.0
    )
    FetchContent_MakeAvailable(swift-atomics)
endif()

# Find required system libraries on Apple platforms
if(APPLE)
    find_library(COREAUDIO_FRAMEWORK CoreAudio REQUIRED)
    find_library(AUDIOTOOLBOX_FRAMEWORK AudioToolbox REQUIRED)
    find_library(FOUNDATION_FRAMEWORK Foundation REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/SimplyCoreAudioTargets.cmake")

check_required_components(SimplyCoreAudio)
